# Required
MINIMAX_API_KEY=sk-cp-REPLACE_ME

# LLM config (placeholders — verify with MiniMax docs)
LITELLM_MODEL=minimax/minimax-m3
LITELLM_API_BASE=https://api.minimax.chat/v1
LITELLM_TIMEOUT=60

# Cost tracker pricing (USD per 1M tokens) — uncomment to override the placeholder defaults.
# MINIMAX_INPUT_PRICE_PER_M=3.0
# MINIMAX_OUTPUT_PRICE_PER_M=15.0

# Optional data source keys (system degrades gracefully if missing)
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
NEWS_API_KEY=

# Logging
LOG_LEVEL=INFO
ENV=development